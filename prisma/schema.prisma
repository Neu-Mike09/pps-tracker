// DA RFO 5 - PPS Communications Tracker — PostgreSQL
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  name         String
  passwordHash String
  role         String   @default("staff")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  createdCommunications Communication[] @relation("CreatedBy")
}

model Communication {
  id               String   @id @default(cuid())
  controlNo        String   @unique
  dateReceived     DateTime
  timeReceived     String?
  dateOfDocument   DateTime?
  documentType     String?
  fromOffice       String?
  subject          String?
  referenceNo      String?
  assignedTo       String?
  targetDate       DateTime?
  dateCompleted    DateTime?
  status           String?
  activityCategory String?
  remarks          String?
  year             Int
  priority         String?
  activityDateTime DateTime?
  photoPath        String?
  sheetSyncedAt    DateTime?
  syncStatus       String   @default("pending")
  syncError        String?
  calendarEventId  String?
  calendarSyncedAt DateTime?
  calendarSyncStatus String @default("pending")
  calendarSyncError String?
  createdById      String?
  createdBy        User?    @relation("CreatedBy", fields: [createdById], references: [id])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  syncLogs         SyncLog[]
  @@index([year])
  @@index([status])
  @@index([assignedTo])
  @@index([dateReceived])
  @@index([targetDate])
}

model SyncLog {
  id              String   @id @default(cuid())
  communicationId String
  communication   Communication @relation(fields: [communicationId], references: [id], onDelete: Cascade)
  status          String
  error           String?
  timestamp       DateTime @default(now())
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model UploadedFile {
  id        String   @id @default(cuid())
  filename  String
  mimeType  String
  data      Bytes
  size      Int
  createdAt DateTime @default(now())
}
