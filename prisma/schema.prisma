// DA RFO 5 - PPS Communications Tracker
// Prisma schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  name         String
  passwordHash String
  role         String   @default("staff") // "admin" | "staff"
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdCommunications Communication[] @relation("CreatedBy")
}

model Communication {
  id              String   @id @default(cuid())
  controlNo       String   @unique
  dateReceived    DateTime
  dateOfDocument  DateTime?
  documentType    String?  // Letter, Memorandum, Email, Indorsement, Invitation, Order, Resolution, Report, Others
  fromOffice      String?
  subject         String?
  referenceNo     String?
  assignedTo      String?  // staff name
  targetDate      DateTime?
  dateCompleted   DateTime?
  status          String?  // Pending, In Progress, For Compliance, Accomplished, Attended, Forwarded, Cancelled, Deferred, For Filing
  activityCategory String? // Coordination, Reporting, Planning, Monitoring, Evaluation, Training/Seminar, Meeting, Field Activity, Others
  remarks         String?
  year            Int
  // New fields (added per user request)
  priority        String?  // Urgent, High, Normal, Low
  activityDateTime DateTime?
  photoPath       String?  // relative URL path to stored photo (e.g. /uploads/PPS-2026-001.jpg)
  // Sync info
  sheetSyncedAt   DateTime?
  syncStatus      String   @default("pending") // pending, synced, failed
  syncError       String?
  // Google Calendar sync info
  calendarEventId String?  // Google Calendar event ID (null = not synced)
  calendarSyncedAt DateTime?
  calendarSyncStatus String @default("pending") // pending, synced, failed, skipped (no date)
  calendarSyncError String?
  // Metadata
  createdById     String?
  createdBy       User?    @relation("CreatedBy", fields: [createdById], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  syncLogs        SyncLog[]

  @@index([year])
  @@index([status])
  @@index([assignedTo])
  @@index([dateReceived])
  @@index([targetDate])
}

model SyncLog {
  id              String   @id @default(cuid())
  communicationId String
  communication   Communication @relation(fields: [communicationId], references: [id], onDelete: Cascade)
  status          String   // success, failed
  error           String?
  timestamp       DateTime @default(now())
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}
